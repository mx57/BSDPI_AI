<Window x:Class="FluxRoute.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:FluxRoute.Converters"
        mc:Ignorable="d"
        Title="FluxRoute"
        Height="520" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanConverter x:Key="InvBool"/>
        <conv:BoolToInstalledConverter x:Key="BoolToInstalled"/>

        <!-- ══ COLORS ══ -->
        <SolidColorBrush x:Key="BgMain"     Color="#0D0F1A"/>
        <SolidColorBrush x:Key="BgSidebar"  Color="#080A12"/>
        <SolidColorBrush x:Key="BgCard"     Color="#0E1120"/>
        <SolidColorBrush x:Key="BgCardAlt"  Color="#0B0D18"/>
        <SolidColorBrush x:Key="BorderDim"  Color="#1A1E30"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#55AAFF"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#9933DD"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00D68F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#DDE4F5"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#3D4260"/>

        <!-- ══ TOGGLE SWITCH STYLE ══ -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Width="44" Height="24" CornerRadius="12" x:Name="Track" Background="#1A1D2C">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" VerticalAlignment="Center"
                                     HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="#4A5170"/>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#1A2E66"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#55AAFF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ NAV ACTIVE BACKGROUND ══ -->
        <LinearGradientBrush x:Key="NavActiveBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#CC4B3FAA" Offset="0"/>
            <GradientStop Color="#AA6630DD" Offset="1"/>
        </LinearGradientBrush>

        <!-- ══ NAV ICON BUTTON ══ -->
        <Style x:Key="NavIconBtn" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Margin="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#151A30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ TITLEBAR BUTTON ══ -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseTitleBtn" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ ACTION BUTTON ══ -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#9BB0D0"/>
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" x:Name="Bd">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A90E2"/>
                                <Setter Property="Foreground" Value="#E2E8F8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtnGreen" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#00D68F"/>
            <Setter Property="BorderBrush" Value="#004D3A"/>
        </Style>
        <Style x:Key="ActionBtnRed" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="BorderBrush" Value="#6B1A1A"/>
        </Style>
        <Style x:Key="ActionBtnAccent" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#4A90E2"/>
            <Setter Property="BorderBrush" Value="#1E3A7A"/>
        </Style>

        <!-- ══ LEGACY ALIASES (backward compat) ══ -->
        <Style x:Key="TermBtn"   TargetType="Button" BasedOn="{StaticResource ActionBtn}"/>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ActionBtnAccent}"/>
        <Style x:Key="GreenBtn"  TargetType="Button" BasedOn="{StaticResource ActionBtnGreen}"/>
        <Style x:Key="RedBtn"    TargetType="Button" BasedOn="{StaticResource ActionBtnRed}"/>

        <!-- ══ SECTION HEADER ══ -->
        <Style x:Key="SecH" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#4A90E2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,8"/>
            <Setter Property="Margin" Value="0,14,0,8"/>
        </Style>

        <!-- ══ LABEL / VALUE ══ -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#4A5170"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Val" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ══ CARD ══ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <!-- ══ LOG AREA ══ -->
        <Style x:Key="LogArea" TargetType="Border">
            <Setter Property="Background" Value="#080B12"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MaxHeight" Value="150"/>
        </Style>

        <!-- ══ SEPARATOR ══ -->
        <Style x:Key="Sep" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Fill" Value="#1E2235"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>

        <!-- ══ COMBOBOX ══ -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="8,0,0,0" VerticalAlignment="Center">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#C8D4EC"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize" Value="12"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#4A5170"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Cursor="Hand" Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#111520" BorderBrush="#1E2235"
                                        BorderThickness="1" CornerRadius="6" Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#161C2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ CHECKBOX ══ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#4A5170"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ══ TEXTBOX ══ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="#C8D4EC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ NAV ACTIVE BG ══ -->
        <Style x:Key="NavActiveHighlight" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="6,2"/>
        </Style>
    </Window.Resources>

    <!-- ROOT -->
    <Border Background="#0c0f17" BorderBrush="#1C1F2E" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════ TITLE BAR ═══════════ -->
            <Border Grid.Row="0" Background="#0C0F17" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <!-- Logo mark -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="26" Height="26" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <!-- Filled gradient triangle -->
                                <Polygon Points="12,2 22,20 2,20">
                                    <Polygon.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6A55EA" Offset="0"/>
                                            <GradientStop Color="#4A90E2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Polygon.Fill>
                                    <Polygon.Effect>
                                        <DropShadowEffect Color="#7A6AFF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                    </Polygon.Effect>
                                </Polygon>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="FluxRoute" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#C8D4EC" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-2,0">
                        <Button Style="{StaticResource TitleBtn}" Click="MinimizeButton_Click">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#4A5170"/>
                        </Button>
                        <Button Style="{StaticResource TitleBtn}">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#4A5170"/>
                        </Button>
                        <Button Style="{StaticResource CloseTitleBtn}" Click="CloseButton_Click">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#4A5170"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════ BODY ═══════════ -->
            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="66"/>
                        <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── SIDEBAR ─── -->
                <Border Grid.Column="0" x:Name="SidebarBorder" Background="#0C0F17"
                        BorderBrush="#181B28" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,8,0,0">
                            <!-- Nav: Главная (0) -->
                            <Grid Margin="0,4,0,4">
                                <Border x:Name="NavBg0" CornerRadius="8" Width="52" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                                    <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Button Style="{StaticResource NavIconBtn}" Command="{Binding SelectTabCommand}" CommandParameter="0">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE80F;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4A5170"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                                        <Setter Property="Foreground" Value="#E9E9F8"/>
                                                        <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#9966FF" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/></Setter.Value></Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <!-- Nav: TG Прокси (1) -->
                            <Grid Margin="0,4,0,4">
                                <Border CornerRadius="8" Width="52" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Button Style="{StaticResource NavIconBtn}" Command="{Binding SelectTabCommand}" CommandParameter="1">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE72E;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4A5170"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                                        <Setter Property="Foreground" Value="#E9E9F8"/>
                                                        <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#9966FF" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/></Setter.Value></Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <!-- Nav: Оркестратор (2) -->
                            <Grid Margin="0,4,0,4">
                                <Border CornerRadius="8" Width="52" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                                    <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Button Style="{StaticResource NavIconBtn}" Command="{Binding SelectTabCommand}" CommandParameter="2">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE9F5;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4A5170"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                                        <Setter Property="Foreground" Value="#E9E9F8"/>
                                                        <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#9966FF" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/></Setter.Value></Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <!-- Nav: Обновление (3) -->
                            <Grid Margin="0,4,0,4">
                                <Border CornerRadius="8" Width="52" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                                    <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Button Style="{StaticResource NavIconBtn}" Command="{Binding SelectTabCommand}" CommandParameter="3">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE777;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4A5170"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                                        <Setter Property="Foreground" Value="#E9E9F8"/>
                                                        <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#9966FF" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/></Setter.Value></Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <!-- Nav: Диагностика (4) -->
                            <Grid Margin="0,4,0,4">
                                <Border CornerRadius="8" Width="52" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
                                                    <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Button Style="{StaticResource NavIconBtn}" Command="{Binding SelectTabCommand}" CommandParameter="4">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE9D9;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#4A5170"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
                                                        <Setter Property="Foreground" Value="#E9E9F8"/>
