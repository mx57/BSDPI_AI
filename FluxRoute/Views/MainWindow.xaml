                                                        </LinearGradientBrush>
                                                    </Polygon.Fill>
                                                    <Polygon.Points>
                                                        0,52 18,46 32,49 50,28 65,36 82,18 100,30 120,14 138,26 158,11 176,22 196,13 214,28 234,16 254,20 270,23 270,66 0,66
                                                    </Polygon.Points>
                                                </Polygon>
                                                <!-- Chart line -->
                                                <Polyline StrokeThickness="2" StrokeLineJoin="Round"
                                                          Canvas.Left="0" Canvas.Top="0">
                                                    <Polyline.Stroke>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#00B86A" Offset="0"/>
                                                            <GradientStop Color="#00E676" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Polyline.Stroke>
                                                    <Polyline.Points>
                                                        0,52 18,46 32,49 50,28 65,36 82,18 100,30 120,14 138,26 158,11 176,22 196,13 214,28 234,16 254,20 270,23
                                                    </Polyline.Points>
                                                    <Polyline.Effect>
                                                        <DropShadowEffect Color="#00E676" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                                    </Polyline.Effect>
                                                </Polyline>
                                            </Canvas>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Card 2: Toggles -->
                                <Border Grid.Row="2" Background="#0E1120" BorderBrush="#1A1E30" BorderThickness="1"
                                        CornerRadius="12" Padding="14,12">
                                    <StackPanel>
                                        <!-- GameFilter -->
                                        <Grid Margin="0,0,0,11">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                    Background="#0E1428" BorderBrush="#1A2244" BorderThickness="1">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xEA18;"
                                                           Foreground="#4A7ECC" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Game Filter" FontFamily="Segoe UI"
                                                       FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding GameFilterEnabled, Mode=OneWay}"/>
                                        </Grid>
                                        <!-- Orchestrator -->
                                        <Grid Margin="0,0,0,11">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                    Background="#100E28" BorderBrush="#201840" BorderThickness="1">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE8C8;"
                                                           Foreground="#8040D8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Оркестратор" FontFamily="Segoe UI"
                                                       FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding OrchestratorRunning}"/>
                                        </Grid>
                                        <!-- AutoStart -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                    Background="#0A1420" BorderBrush="#142030" BorderThickness="1">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE909;"
                                                           Foreground="#3A9090" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Автозапуск" FontFamily="Segoe UI"
                                                       FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding AutoStartEnabled}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Card 3: Donut stats -->
                                <Border Grid.Row="4" Background="#0E1120" BorderBrush="#1A1E30" BorderThickness="1"
                                        CornerRadius="12" Padding="14,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Donut -->
                                        <Viewbox Grid.Column="0" Width="62" Height="62" VerticalAlignment="Center">
                                            <Canvas Width="64" Height="64">
                                                <Ellipse Width="64" Height="64" StrokeThickness="8" Fill="Transparent"
                                                         Stroke="#111828"/>
                                                <Path StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent">
                                                    <Path.Stroke>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#4A80E2" Offset="0"/>
                                                            <GradientStop Color="#5BADFF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Path.Stroke>
                                                    <Path.Data>
                                                        <PathGeometry>
                                                            <PathFigure StartPoint="32,4" IsClosed="False">
                                                                <ArcSegment Point="60,32" Size="28,28"
                                                                            SweepDirection="Clockwise" IsLargeArc="False"/>
                                                            </PathFigure>
                                                        </PathGeometry>
                                                    </Path.Data>
                                                    <Path.Effect>
                                                        <DropShadowEffect Color="#4A80E2" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                    </Path.Effect>
                                                </Path>
                                                <Path StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent">
                                                    <Path.Stroke>
                                                        <SolidColorBrush Color="#8040CC"/>
                                                    </Path.Stroke>
                                                    <Path.Data>
                                                        <PathGeometry>
                                                            <PathFigure StartPoint="60,32" IsClosed="False">
                                                                <ArcSegment Point="32,60" Size="28,28"
                                                                            SweepDirection="Clockwise" IsLargeArc="False"/>
                                                            </PathFigure>
                                                        </PathGeometry>
                                                    </Path.Data>
                                                    <Path.Effect>
                                                        <DropShadowEffect Color="#8040CC" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                    </Path.Effect>
                                                </Path>
                                                <Path StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent">
                                                    <Path.Stroke>
                                                        <SolidColorBrush Color="#00C47A"/>
                                                    </Path.Stroke>
                                                    <Path.Data>
                                                        <PathGeometry>
                                                            <PathFigure StartPoint="32,60" IsClosed="False">
                                                                <ArcSegment Point="10,42" Size="28,28"
                                                                            SweepDirection="Clockwise" IsLargeArc="False"/>
                                                            </PathFigure>
                                                        </PathGeometry>
                                                    </Path.Data>
                                                    <Path.Effect>
                                                        <DropShadowEffect Color="#00C47A" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                    </Path.Effect>
                                                </Path>
                                            </Canvas>
                                        </Viewbox>

                                        <!-- Legend -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                                <Ellipse Width="7" Height="7" Fill="#5BADFF" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding AdminText}" FontFamily="Segoe UI"
                                                           FontSize="11" Foreground="#7080A8"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                                <Ellipse Width="7" Height="7" Fill="#8040CC" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding WinwsText}" FontFamily="Segoe UI"
                                                           FontSize="11" Foreground="#7080A8"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7" Fill="#00C47A" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding CurrentEngineVersion, Mode=OneWay}" FontFamily="Segoe UI"
                                                           FontSize="11" Foreground="#7080A8"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ╔══════════ TAB 1: TG ПРОКСИ ══════════╗ -->
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Opacity" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12">
                                <Border Background="#1C1800" BorderBrush="#4A3800" BorderThickness="1" CornerRadius="8"
                                        Padding="10,8" Margin="0,0,0,12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding TgProxyInstalled}" Value="False"/>
                                                        <Condition Binding="{Binding IsTgProxyDownloading}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#F0B429" FontSize="12" FontWeight="SemiBold"
                                                   Margin="0,0,0,4" Text="TG WS Proxy не установлен"/>
                                        <Button Content="Установить TG WS Proxy" Style="{StaticResource ActionBtnAccent}"
                                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                                Command="{Binding DownloadTgProxyCommand}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#0D1F0D" BorderBrush="#1A4A1A" BorderThickness="1" CornerRadius="8"
                                        Padding="10,8" Margin="0,0,0,12"
                                        Visibility="{Binding IsTgProxyDownloading, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#66BB6A" FontSize="12" FontWeight="SemiBold"
                                                   Margin="0,0,0,4" Text="Установка TG WS Proxy..."/>
                                        <TextBlock Text="{Binding TgProxyDownloadStatus}" FontFamily="Segoe UI"
                                                   Foreground="#A5D6A7" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Style="{StaticResource SecH}" Text="УПРАВЛЕНИЕ" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Margin="0,0,10,0" Command="{Binding ToggleTgProxyCommand}" IsEnabled="{Binding TgProxyInstalled}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnGreen}">
                                                <Setter Property="Content" Value="Запустить прокси"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TgProxyRunning}" Value="True">
                                                        <Setter Property="Content" Value="Остановить прокси"/>
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                        <Setter Property="BorderBrush" Value="#6B1A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Открыть в Telegram" Style="{StaticResource ActionBtnAccent}" Margin="0,0,10,0"
                                            Command="{Binding OpenInTelegramCommand}" IsEnabled="{Binding TgProxyRunning}"/>
                                    <Button Content="Скопировать ссылку" Style="{StaticResource ActionBtn}"
                                            Command="{Binding CopyTgLinkCommand}" IsEnabled="{Binding TgProxyInstalled}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource Lbl}" Text="Версия: " Margin="0,0,4,0"/>
                                    <TextBlock Style="{StaticResource Val}" Text="{Binding TgProxyVersion}"/>
                                </StackPanel>
                                <Rectangle Style="{StaticResource Sep}"/>
                                <TextBlock Style="{StaticResource SecH}" Text="ПОДКЛЮЧЕНИЕ" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource Lbl}" Text="IP-адрес" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding TgProxyHost, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource Lbl}" Text="Порт" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding TgProxyPort, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding TgProxySecret, UpdateSourceTrigger=PropertyChanged}"
                                             Height="30" VerticalContentAlignment="Center" FontFamily="Consolas"/>
                                    <Button Grid.Column="2" Height="30" Width="36" Style="{StaticResource ActionBtnAccent}"
                                            Padding="0" Command="{Binding GenerateTgProxySecretCommand}">
                                        <TextBlock Text="↻" FontSize="14"/>
                                    </Button>
                                </Grid>
                                <Rectangle Style="{StaticResource Sep}"/>
                                <TextBlock Style="{StaticResource SecH}" Text="ДАТАЦЕНТРЫ TELEGRAM (DC → IP)" Margin="0,0,0,6"/>
                                <TextBlock Style="{StaticResource Lbl}" Text="Формат: номер:IP" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding TgProxyDcIps, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" MinHeight="56" MaxHeight="100"
                                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                                         VerticalContentAlignment="Top" Padding="6" Margin="0,0,0,12"/>
                                <Rectangle Style="{StaticResource Sep}"/>
                                <TextBlock Style="{StaticResource SecH}" Text="CLOUDFLARE PROXY" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <CheckBox Content="Включить CF-прокси" IsChecked="{Binding TgProxyCfEnabled}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <CheckBox Content="Приоритет" IsChecked="{Binding TgProxyCfPriority}" IsEnabled="{Binding TgProxyCfEnabled}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <CheckBox IsChecked="{Binding TgProxyCfDomainEnabled}" IsEnabled="{Binding TgProxyCfEnabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Text="{Binding TgProxyCfDomain, UpdateSourceTrigger=PropertyChanged}"
                                             Height="30" VerticalContentAlignment="Center" FontSize="12" Width="260"
                                             IsEnabled="{Binding TgProxyCfDomainEnabled}"/>
                                </StackPanel>
                                <Rectangle Style="{StaticResource Sep}"/>
                                <TextBlock Style="{StaticResource SecH}" Text="ЛОГИ И ПРОИЗВОДИТЕЛЬНОСТЬ" Margin="0,0,0,8"/>
                                <CheckBox Content="Подробное логирование (verbose)" IsChecked="{Binding TgProxyVerbose}" Margin="0,0,0,8"/>
                                <TextBlock Style="{StaticResource Lbl}" Text="Буфер, КБ" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding TgProxyBufKb, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Style="{StaticResource Lbl}" Text="Пул WebSocket-сессий" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding TgProxyPoolSize, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Style="{StaticResource Lbl}" Text="Макс. размер лога, МБ" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding TgProxyLogMaxMb, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8"/>
                                <CheckBox Content="Предпочитать IPv4" IsChecked="{Binding TgProxyPreferIPv4}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- ╔══════════ TAB 2: ОРКЕСТРАТОР ══════════╗ -->
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Opacity" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12">
                                <TextBlock Style="{StaticResource SecH}" Text="УПРАВЛЕНИЕ" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Margin="0,0,10,0" Command="{Binding ToggleOrchestratorCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                                <Setter Property="Content" Value="Запустить оркестратор"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding OrchestratorRunning}" Value="True">
                                                        <Setter Property="Content" Value="Остановить оркестратор"/>
                                                        <Setter Property="BorderBrush" Value="#6B1A1A"/>
                                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Проверить сейчас" Style="{StaticResource ActionBtn}" Command="{Binding CheckNowCommand}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Style="{StaticResource Lbl}" Text="Интервал (мин): " Margin="0,0,8,0"/>
                                    <TextBox Text="{Binding OrchestratorInterval, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" Height="28" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Style="{StaticResource Lbl}" Text="Следующая проверка: " Margin="0,0,4,0"/>
                                    <TextBlock Style="{StaticResource Val}" Text="{Binding OrchestratorNextCheck}"/>
                                </StackPanel>
                                <Rectangle Style="{StaticResource Sep}"/>
                                <TextBlock Style="{StaticResource SecH}" Text="САЙТЫ ДЛЯ ПРОВЕРКИ"/>
                                <WrapPanel Margin="0,0,0,8">
                                    <CheckBox Content="YouTube"   IsChecked="{Binding SiteYouTube}"   Margin="0,4,16,4"/>
                                    <CheckBox Content="Discord"   IsChecked="{Binding SiteDiscord}"   Margin="0,4,16,4"/>
                                    <CheckBox Content="Google"    IsChecked="{Binding SiteGoogle}"    Margin="0,4,16,4"/>
                                    <CheckBox Content="Twitch"    IsChecked="{Binding SiteTwitch}"    Margin="0,4,16,4"/>
                                    <CheckBox Content="Instagram" IsChecked="{Binding SiteInstagram}" Margin="0,4,16,4"/>
                                    <CheckBox Content="Telegram"  IsChecked="{Binding SiteTelegram}"  Margin="0,4,16,4"/>
                                </WrapPanel>
                                <Rectangle Style="{StaticResource Sep}"/>
                                <TextBlock Style="{StaticResource SecH}" Text="РЕЙТИНГ ПРОФИЛЕЙ"/>
                                <Button HorizontalAlignment="Left" Margin="0,0,0,10" Command="{Binding ScanProfilesCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtnAccent}">
                                            <Setter Property="Content" Value="Сканировать все профили"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="Content" Value="Сканирование..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock Text="{Binding ScanProgressText}" FontFamily="Segoe UI" Foreground="#4A90E2"
                                           FontSize="12" Margin="0,0,0,8"
                                           Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                                <ItemsControl ItemsSource="{Binding ProfileScores}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#111520" CornerRadius="6" Padding="10,6" Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                               FontFamily="Segoe UI" Foreground="#C8D4EC" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding ScoreText}"
                                                               FontFamily="Segoe UI" Foreground="#4A90E2" FontSize="12"
                                                               FontWeight="Bold" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- ╔══════════ TAB 3: ОБНОВЛЕНИЕ ══════════╗ -->
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Opacity" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12">
                                <TextBlock Style="{StaticResource SecH}" Text="FLOWSEAL ZAPRET" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                        <RowDefinition Height="26"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}" Text="Текущая версия:"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding CurrentEngineVersion}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Lbl}" Text="Доступная версия:"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding Updates.LatestRemoteVersion}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Lbl}" Text="Статус:"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding UpdateStatus}"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Margin="0,0,10,0" Command="{Binding CheckUpdatesCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                                <Setter Property="Content" Value="Проверить"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Content" Value="Обновление..."/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Command="{Binding InstallUpdatesCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnAccent}">
                                                <Setter Property="Content" Value="Обновить"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUpdating}" Value="True">
